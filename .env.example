# ============================================
# WHOP API CREDENTIALS
# Get these from: https://whop.com/dashboard
# Go to your organization > API Keys section
# ============================================

# Your app's API key (required)
WHOP_API_KEY=your_api_key_here

# Your app's ID (required)
WHOP_APP_ID=your_app_id_here

# Your app's agent user ID (required)
WHOP_AGENT_USER_ID=your_agent_user_id_here

# Webhook secret for validating incoming webhooks (optional but recommended)
WHOP_WEBHOOK_SECRET=your_webhook_secret_here

# ============================================
# DATABASE
# Using Prisma with SQLite for dev, PostgreSQL for production
# For production, use a service like:
#   - Vercel Postgres (free tier available)
#   - Supabase (free tier available)
#   - PlanetScale (free tier available)
#   - Railway (free tier available)
# ============================================

# SQLite for development (zero config, works immediately)
DATABASE_URL="file:./dev.db"

# For production, use PostgreSQL:
# DATABASE_URL="postgresql://user:password@host:5432/whoplevel?sslmode=require"
